# ─── Supabase (Required) ──────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=your-admin-chat-id
TELEGRAM_WEBHOOK_SECRET=random-secret-for-webhook-validation

# ─── Algorand ─────────────────────────────────────────────────
VITE_AGENT_WALLET_ADDRESS=RVHOYLPY4L47JYCYEMCP7EMEC2AZ3HV53YHSL2ZISX6PSO5EQ6H5YVAE5U
AGENT_WALLET_MNEMONIC=your 25 word mnemonic here
ALGO_NETWORK=testnet

# Generate a new agent wallet:
#   node -e "const a=require('algosdk');const k=a.generateAccount();console.log('Address:',k.addr);console.log('Mnemonic:',a.secretKeyToMnemonic(k.sk))"

# ─── Agent / Railway ──────────────────────────────────────────
OPENCLAW_RAILWAY_URL=https://bliss-agent-agent-production.up.railway.app
VITE_OPENCLAW_RAILWAY_URL=https://bliss-agent-agent-production.up.railway.app
SUBSCRIPTION_CREDS_KEY=64-hex-chars-for-aes256-encryption
OPENCLAW_GATEWAY_TOKEN=random-secret-for-agent-api-auth

# Generate SUBSCRIPTION_CREDS_KEY:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ─── AI / LLM ────────────────────────────────────────────────
CEREBRAS_API_KEY=csk-...
# Used for: Telegram AI chatbot (primary brain, Llama 3.1 70B)
# Get from: https://cloud.cerebras.ai

GOOGLE_API_KEY=AIza...
# Used for: Voice transcription, AI Financial Resume
# Get from: https://aistudio.google.com/apikey

GROQ_API_KEY=gsk_...
# Used for: AI Optimizer page
# Get from: https://console.groq.com

# ─── x402 Payment Protocol ───────────────────────────────────
X402_PAY_TO_ADDRESS=RVHOYLPY4L47JYCYEMCP7EMEC2AZ3HV53YHSL2ZISX6PSO5EQ6H5YVAE5U
# The Algorand address that receives x402 payments (usually same as agent wallet)

# ─── Smart Contract App IDs (Testnet) ────────────────────────
VITE_SERVICE_REGISTRY_APP_ID=759205676
VITE_AGENT_V2_APP_ID=759205677
SERVICE_REGISTRY_APP_ID_TESTNET=759205676

# ─── MCP Server (Optional) ───────────────────────────────────
# MCP_AUTH_TOKEN=optional-master-token-for-testing
# MCP_DEFAULT_USER_ID=your-supabase-user-uuid
# These are only needed for quick testing without the mcp_api_tokens table.
# In production, each user generates their own token via /api/mcp-token.

# ─── Optional / Future ───────────────────────────────────────
# VITE_GOOGLE_API_KEY is NOT needed — AI calls go through server-side /api/ai-summary
# OPENAI_API_KEY=sk-... (not currently used)
